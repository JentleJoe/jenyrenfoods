{
  "name": "jenyrenfoods-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node -e \"const fs = require('node:fs'); fs.rmSync('dist', { recursive: true, force: true });\"",
    "build": "npm run build:client && npm run build:ssr && npm run prerender",
    "build:client": "vite build --outDir dist/client",
    "build:ssr": "vite build --ssr src/entry-server.jsx --outDir dist/server",
    "prerender": "node scripts/prerender.mjs",
    "lint": "eslint .",
    "preview": "vite preview --outDir dist/client"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "lucide-react": "^0.263.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.9.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^8.0.8",
    "vite-imagetools": "^10.0.0"
  }
}
